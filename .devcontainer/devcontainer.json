{
  "name": "0 C.E. - GDD",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "containerEnv": {
    "LANG": "en_US.UTF-8",
    "LC_ALL": "en_US.UTF-8"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "myriad-dreamin.tinymist",
        "yzhang.markdown-all-in-one",
        "streetsidesoftware.code-spell-checker"
      ],
      "settings": {
        "files.eol": "\n",
        "editor.formatOnSave": true
      }
    }
  },
  "postCreateCommand": "bash -lc 'set -e; typst --version; typstyle --version; echo typstyle available; pandoc --version | head -n 2; python3 --version; echo DevContainer ready.'"
}